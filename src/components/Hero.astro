---
import { siteConfig } from "../config";
---

<div
  id="hero"
  class="relative isolate overflow-hidden bg-white py-24 md:min-h-screen"
  style={`--accent-color: ${siteConfig.accentColor}`}
>
  <div
    class="absolute inset-0 -z-10"
    style={`background: radial-gradient(circle at top left, ${siteConfig.accentColor}26 0%, ${siteConfig.accentColor}14 22%, rgba(255, 255, 255, 0.92) 58%, white 100%)`}
  ></div>
  <div class="absolute inset-0 -z-10 opacity-60">
    <div class="absolute -top-20 left-0 h-72 w-72 rounded-full blur-3xl" style={`background-color: ${siteConfig.accentColor}20`}></div>
    <div class="absolute bottom-0 right-0 h-80 w-80 rounded-full blur-3xl" style={`background-color: ${siteConfig.accentColor}18`}></div>
  </div>

  <div class="mx-auto flex min-h-screen max-w-7xl flex-col justify-center gap-16 px-8 py-20 sm:px-12 md:px-16 lg:flex-row lg:items-center lg:gap-20 lg:px-24">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.28em] text-gray-500">
        Portfolio
      </p>
      <h1 class="mt-5 text-balance text-5xl font-bold tracking-tight text-gray-900 sm:text-6xl lg:text-8xl">
        Aarav <span style={`color: ${siteConfig.accentColor}`}>Kalkar</span>
      </h1>
      <p class="mt-6 max-w-2xl text-xl font-medium text-gray-700 sm:text-2xl">
        {siteConfig.title}
      </p>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-gray-600 sm:text-xl">
        {siteConfig.tagline}
      </p>

      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href={siteConfig.resumeUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-full px-6 py-3 text-sm font-semibold text-white shadow-sm transition-transform duration-300 hover:-translate-y-0.5"
          style={`background-color: ${siteConfig.accentColor}`}
        >
          View Resume
        </a>
        <a
          href="#projects"
          class="inline-flex items-center rounded-full border border-gray-300 bg-white px-6 py-3 text-sm font-semibold text-gray-800 transition-colors duration-300 hover:border-gray-400 hover:bg-gray-50"
        >
          Explore Projects
        </a>
        <a
          href="#contact"
          class="inline-flex items-center rounded-full border border-transparent px-6 py-3 text-sm font-semibold text-gray-700 transition-colors duration-300 hover:text-gray-900"
        >
          Contact Me
        </a>
      </div>

      <div class="mt-10 flex gap-x-5 text-gray-700">
        {
          siteConfig.social?.email && (
            <a
              href={`mailto:${siteConfig.social.email}`}
              aria-label="Email"
              class="transition-colors duration-300 hover:text-[var(--accent-color)]"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7">
                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" />
                <path d="M3 7l9 6l9 -6" />
              </svg>
            </a>
          )
        }
        {
          siteConfig.social?.linkedin && (
            <a
              href={siteConfig.social.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn"
              class="transition-colors duration-300 hover:text-[var(--accent-color)]"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7">
                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                <path d="M8 11v5" />
                <path d="M8 8v.01" />
                <path d="M12 16v-5" />
                <path d="M16 16v-3a2 2 0 1 0 -4 0" />
                <path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4z" />
              </svg>
            </a>
          )
        }
        {
          siteConfig.social?.github && (
            <a
              href={siteConfig.social.github}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="GitHub"
              class="transition-colors duration-300 hover:text-[var(--accent-color)]"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7">
                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" />
              </svg>
            </a>
          )
        }
      </div>
    </div>

    <div class="flex shrink-0 justify-center lg:justify-end">
      <div class="relative">
        <div class="absolute inset-0 rounded-[2rem] blur-2xl" style={`background: linear-gradient(135deg, ${siteConfig.accentColor}30, rgba(255,255,255,0.4))`}></div>
        <div class="relative overflow-hidden rounded-[2rem] border border-white/70 bg-white/90 p-4 shadow-2xl backdrop-blur">
          <img
            src={siteConfig.profileImage}
            alt={`${siteConfig.name} profile photo`}
            class="h-[320px] w-[260px] rounded-[1.5rem] object-cover sm:h-[420px] sm:w-[320px]"
          />
        </div>
      </div>
    </div>
  </div>
</div>
